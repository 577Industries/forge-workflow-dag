{
  "name": "@577-industries/workflow-dag",
  "version": "1.0.0",
  "description": "YAML-to-DAG workflow compiler with Kahn's topological sort, cycle detection, and parallel group identification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["workflow", "dag", "topological-sort", "kahn", "yaml", "compiler", "orchestration", "parallel"],
  "author": "577 Industries",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/577Industries/forge-workflow-dag" },
  "homepage": "https://www.577industries.com/forge",
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
